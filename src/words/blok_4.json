        "subtopic_lat": "Frazе za kuvanje",
        "entries": [
          {
            "sr_cyr": "прекипело ми је",
            "sr_lat": "prekipelo mi je",
            "ru": "мне надоело"
          },
          {
            "sr_cyr": "скувао сам се",
